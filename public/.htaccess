# ----------------------------------------------------------------------
# Apache Security and Performance Configuration (.htaccess)
# ----------------------------------------------------------------------

# 1. Prevent Directory Listings and Server Info Disclosure
Options -Indexes
ServerSignature Off

# 2. Prevent Access to Config, Package, Locks, and Logs
<FilesMatch "^(package\.json|package-lock\.json|tsconfig\.json|vite\.config\.ts|tailwind\.config\.js|postcss\.config\.js|metadata\.json|\.htaccess|\.git.*|\.env.*)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# 3. SPA Friendly Routing & Rewrite Security
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Force HTTPS redirection
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # Prevent Cross-Site Tracing (XST) by disabling TRACE and TRACK
  RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK) [NC]
  RewriteRule .* - [F]
  
  # Protect critical system files from being accessed
  RewriteRule ^\.(git|github|env) - [F,L]
  
  # Fallback all other requests to index.html if not a physical file or directory
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

# 4. Security Headers
<IfModule mod_headers.c>
  # Avoid Clickjacking by restricting framing
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # Enable XSS protection filter in older browsers
  Header set X-XSS-Protection "1; mode=block"
  
  # Control referrer information sent with requests
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Restrict cross-domain Flash/PDF/etc. policy files
  # Header set X-Permitted-Cross-Domain-Policies "none"

  # Restrict browser APIs and sensors
  # Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  
  # Content Security Policy (CSP)
  # Restricts execution, font, styles, and resource loading to minimum required origins
  # Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://use.typekit.net data:; img-src 'self' data:; connect-src 'self';"

  # Enable Strict Transport Security (HSTS)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# 5. Gzip/Deflate Compression (Performance & Speed)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json image/svg+xml
  
  # Mark proxies to cache compressed and uncompressed files separately
  Header append Vary User-Agent
</IfModule>

# 6. Caching Control (Performance & Speed)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  
  # Do not cache HTML files to ensure instant updates
  ExpiresByType text/html "access plus 0 seconds"
  
  # Cache static assets for a long duration (1 year)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>
